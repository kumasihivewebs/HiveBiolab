SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=127.0.0.1 localhost api.biolab.kumasihive.com
FRONTEND_ORIGINS=http://localhost:8080 http://127.0.0.1:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080 http://127.0.0.1:8080

DB_NAME=biolab
DB_USER=africaosh
DB_PASSWORD=replace-with-a-strong-postgres-password
DB_HOST=db
DB_PORT=5432

# Optional alternative for a managed/external Postgres service:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL_REQUIRE=false
DATABASE_CONN_MAX_AGE=600
SECURE_SSL_REDIRECT=false
USE_X_FORWARDED_HOST=true
